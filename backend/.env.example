# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────
# REQUIRED — Core
# ──────────────────────────────────────────────
DATABASE_URL=sqlite:///./restarentai.db
JWT_SECRET=change-me-to-a-random-string
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,https://zenzeerestaurantai.netlify.app

# ──────────────────────────────────────────────
# Feature Flags
# ──────────────────────────────────────────────
LLM_ENABLED=false
CALL_ORDER_LLM_ORCHESTRATOR=false
AI_CALL_REALTIME_ENABLED=false

# ──────────────────────────────────────────────
# AI Call Provider (vapi or retell)
# ──────────────────────────────────────────────
AI_CALL_PROVIDER=retell
AI_CALL_PROVIDER_PUBLIC_KEY=
AI_CALL_PROVIDER_ASSISTANT_ID=
AI_CALL_PROVIDER_ASSISTANT_ID_EN=
AI_CALL_PROVIDER_ASSISTANT_ID_TA=
AI_CALL_PROVIDER_PHONE_NUMBER_ID=
AI_CALL_PROVIDER_AGENT_ID=
AI_CALL_PROVIDER_AGENT_ID_EN=
AI_CALL_PROVIDER_AGENT_ID_TA=

# ──────────────────────────────────────────────
# Retell (required when AI_CALL_PROVIDER=retell)
# ──────────────────────────────────────────────
RETELL_API_KEY=key_your_retell_api_key
RETELL_SERVER_URL=
RETELL_WEBHOOK_SECRET=

# ──────────────────────────────────────────────
# VAPI (required when AI_CALL_PROVIDER=vapi)
# ──────────────────────────────────────────────
VAPI_SERVER_URL=
VAPI_WEBHOOK_SECRET=

# ──────────────────────────────────────────────
# LLM / NLP APIs
# ──────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
GEMINI_API_KEY=your-gemini-api-key
SARVAM_API_KEY=

# ──────────────────────────────────────────────
# External Services
# ──────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=your-google-api-key

# ──────────────────────────────────────────────
# Payments (Stripe)
# ──────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STANDARD_PRICE_ID=
STRIPE_CORPORATE_PRICE_ID=
FRONTEND_URL=http://localhost:5173

# ──────────────────────────────────────────────
# Email (SMTP) — optional
# ──────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ──────────────────────────────────────────────
# Twilio (SMS/WhatsApp) — optional
# ──────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=
